# Portugal Active — Master Data Supabase credentials
# Copy this file to `.env` and fill in real values from Sprint 0 (Cowork output).
# The `.env` file is git-ignored — never commit credentials.

# From Supabase Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# From Supabase Project Settings → Database → Connection string (URI mode, with password)
# Example: postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_CONNECTION_STRING=postgresql://postgres:PASSWORD@HOST:5432/postgres

# Where the source Excel files live on disk.
# Default points at ~/Downloads where the Sprint 1 source files were dropped.
SOURCE_DATA_DIR=/Users/ricardoviana/Downloads

# Sprint 4 — Guesty Open API v2 OAuth2 credentials.
# Get from Guesty Dashboard → Apps → OAuth2 application.
GUESTY_CLIENT_ID=0oa...
GUESTY_CLIENT_SECRET=...
